# 可选：接入任意 OpenAI 兼容大模型。
# 当前项目已适配 GLM-4.5-Flash / 智谱 BigModel OpenAI 兼容接口。
# 不配置时，后端会使用本地规则引擎生成回复。
OPENAI_API_KEY=
OPENAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
OPENAI_MODEL=glm-4.5-flash
OPENAI_TIMEOUT=30
GLM_DISABLE_THINKING=1

# 后续可接入火山、Azure、HeyGen、D-ID 等服务。
TTS_PROVIDER=browser
DIGITAL_HUMAN_PROVIDER=css-avatar
